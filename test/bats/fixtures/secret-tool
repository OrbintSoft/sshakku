#!/bin/sh
# Stub secret-tool for the bats shell-plumbing suite: a file-backed
# key-value store standing in for a real Secret Service, so a headless
# container with no D-Bus session can still exercise SecretToolBackend's
# fallback path (internal/keys/secret.go). Understands only the exact
# invocations that backend issues: "lookup service S username U", "store
# --label=L service S username U" (passphrase on stdin), and "clear
# service S username U". Entries live under $SSHAKKU_TEST_VAULT, one file
# per service/user pair.
set -eu

vault="${SSHAKKU_TEST_VAULT:?SSHAKKU_TEST_VAULT must be set}"
mkdir -p "$vault"

verb="$1"
shift

service=""
user=""
while [ "$#" -gt 0 ]; do
	case "$1" in
	service)
		service="$2"
		shift 2
		;;
	username)
		user="$2"
		shift 2
		;;
	*)
		shift
		;;
	esac
done

entry="$vault/$service-$user"

case "$verb" in
lookup)
	[ -f "$entry" ] || exit 1
	cat "$entry"
	;;
store)
	cat >"$entry"
	;;
clear)
	rm -f "$entry"
	;;
*)
	echo "stub secret-tool: unsupported verb $verb" >&2
	exit 2
	;;
esac
